{
 "name": "hr-app",
 "version": "1.0.0",
 "private": true,
 "workspaces": [
  "apps/*",
  "packages/*"
 ],
 "scripts": {
  "pretest": "bash scripts/check-services.sh",
  "test": "playwright test",
  "test:headed": "playwright test --headed",
  "test:ui": "playwright test --ui",
  "test:debug": "playwright test --debug",
  "test:chromium": "playwright test --project=chromium",
  "test:firefox": "playwright test --project=firefox",
  "test:webkit": "playwright test --project=webkit",
  "test:report": "playwright show-report",
  "e2e": "playwright test",
  "e2e:headed": "playwright test --headed",
  "e2e:ui": "playwright test --ui",
  "coverage:e2e:merge": "node scripts/merge-e2e-coverage.js frontend",
  "coverage:e2e:merge:server": "node scripts/merge-e2e-coverage.js server",
  "coverage:e2e:merge:all": "node scripts/merge-e2e-coverage.js all",
  "services:start": "bash scripts/start-all-services.sh",
  "services:stop": "bash scripts/stop-all-services.sh",
  "services:check": "bash scripts/check-services.sh",
  "docker:ship": "docker build --platform linux/amd64 -f apps/frontend/Dockerfile -t hr-frontend-app . && docker build --platform linux/amd64 -f apps/server/Dockerfile -t hr-server-app . && docker save hr-frontend-app -o 4airport/hr-frontend-app.tar && docker save hr-server-app -o 4airport/hr-server-app.tar"
 },
 "devDependencies": {
  "@faker-js/faker": "^10.1.0",
  "@playwright/test": "^1.57.0",
  "istanbul-lib-coverage": "^3.2.2",
  "istanbul-lib-report": "^3.0.1",
  "istanbul-reports": "^3.2.0",
  "nyc": "^18.0.0",
  "vite-plugin-istanbul": "^9.0.1"
 }
}
