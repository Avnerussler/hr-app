{
    "name": "server",
    "version": "1.0.0",
    "main": "index.js",
    "scripts": {
        "dev": "nodemon --watch src --watch ../../packages/shared-types/src --ext ts,json src/server.ts",
        "build": "tsc",
        "start": "node dist/server.js",
        "test": "jest --watchAll=false",
        "test:watch": "jest --watch",
        "test:coverage": "jest --coverage",
        "migrate:to-explicit-models": "ts-node src/migrations/toExplicitModels/index.ts",
        "migrate:to-explicit-models:dry-run": "ts-node src/migrations/toExplicitModels/index.ts --dry-run",
        "docker:build": "docker build -f Dockerfile -t hr-server-app ../..",
        "docker:build:linux": "docker build --platform linux/amd64 -f Dockerfile -t hr-server-app ../..",
        "docker:run": "docker run -p 3002:3002 hr-server-app",
        "docker:compose": "docker compose -f 'docker/compose.yml' up -d --build",
        "docker:all": "npm run build && npm run docker:build && npm run docker:run"
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "description": "",
    "dependencies": {
        "@faker-js/faker": "^10.0.0",
        "@hr-app/shared-types": "*",
        "cors": "^2.8.5",
        "date-fns": "^4.1.0",
        "dotenv": "^16.4.7",
        "exceljs": "^3.4.0",
        "express": "^4.21.2",
        "joi": "^18.0.1",
        "minio": "^8.0.4",
        "mongoose": "^8.10.1",
        "multer": "^1.4.5-lts.1",
        "uuid": "^11.1.0",
        "winston": "^2.4.6",
        "zod": "^3.24.0"
    },
    "devDependencies": {
        "@types/cors": "^2.8.17",
        "@types/express": "^5.0.0",
        "@types/jest": "^29.5.14",
        "@types/joi": "^17.2.2",
        "@types/minio": "^7.1.0",
        "@types/mongoose": "^5.11.96",
        "@types/multer": "^1.4.12",
        "@types/node": "^22.13.4",
        "@types/uuid": "^10.0.0",
        "jest": "^29.7.0",
        "nodemon": "^3.1.9",
        "ts-jest": "^29.2.5",
        "ts-node": "^10.9.2",
        "typescript": "^5.7.3"
    }
}
