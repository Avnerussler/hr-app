{
    "compilerOptions": {
        "target": "es2016",
        "module": "commonjs",
        "strict": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "skipLibCheck": true,
        "declaration": true,
        "outDir": "./dist/cjs",
        "rootDir": "./src"
    },
    "include": ["src/**/*"]
}
